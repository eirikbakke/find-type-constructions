{
  "name": "find-type-constructions",
  "displayName": "Find Type Constructions",
  "description": "Find places where a TypeScript interface, type alias, or class is constructed: object literals assigned to the type, `new` expressions, and JSX call sites whose props match. Addresses gaps in 'Go to Implementations' (no support for interfaces) and 'Find All References' (which never includes interface construction sites, since the construction is an object literal with no textual mention of the interface name).",
  "keywords": [
    "typescript",
    "interface",
    "type",
    "class",
    "react",
    "props",
    "find references",
    "go to implementation",
    "object literal",
    "new expression",
    "jsx",
    "construction",
    "instantiation",
    "structural typing",
    "refactoring"
  ],
  "version": "0.0.1",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/eirikbakke/find-type-constructions.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "find-type-constructions.find",
        "title": "Find Type Constructions"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "find-type-constructions.find",
          "when": "editorLangId == typescript || editorLangId == typescriptreact",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "find-type-constructions",
          "title": "Type Constructions",
          "icon": "resources/panel-icon.svg"
        }
      ]
    },
    "views": {
      "find-type-constructions": [
        {
          "id": "find-type-constructions.results",
          "name": "Type Constructions"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test src/tests/*.test.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "minimatch": "^10.2.5",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.0.0"
  }
}
